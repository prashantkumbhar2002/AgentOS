VITE_API_URL=http://localhost:3000

# Optional LangSmith cross-link. When set, the TraceDrawer renders a small
# "View in LangSmith" link on each llm_call event that has a langsmithRunId.
# When unset (or not http(s)), the dashboard hides the link entirely — no
# traffic is sent to LangSmith from the dashboard regardless.
#
# Cloud:        https://smith.langchain.com
# Self-hosted:  http://localhost:1984  (or wherever your LangSmith is)
# VITE_LANGSMITH_UI_BASE=https://smith.langchain.com

# Optional LangSmith org id. Adds an `/o/<org>` segment to deep-links so they
# land on org-scoped pages. Leave unset for self-hosted deployments that
# don't use org-scoped routing.
# VITE_LANGSMITH_ORG_ID=
